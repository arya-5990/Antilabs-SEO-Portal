# OpenAI API Key for the AI Analyzer Service
OPENAI_API_KEY=your_openai_api_key_here

# Groq (groq.com) API Key & Model (Optional)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini API Key and Project Details
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_PROJECT_NAME=projects/your_project_number
GEMINI_PROJECT_NUMBER=your_project_number

# Optional: Set environment to development or production
ENVIRONMENT=development

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
